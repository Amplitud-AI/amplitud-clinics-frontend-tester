# Copy to `.env` (this repo documents `.env`; Next.js loads it by default.)
# CLINIC_PROVISIONING_SECRET lives on the Agnentic server; Phase A panel in the UI accepts it (never NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_AGNENTIC_BASE_URL=http://127.0.0.1:8001
NEXT_PUBLIC_WHATSAPP_SERVICE_URL=http://127.0.0.1:3002
# Optional: override OAuth return target used in Phase C when running tester locally.
# Example: https://your-dashboard-domain/oauth/callback
NEXT_PUBLIC_GOOGLE_OAUTH_RETURN_URL=
